{
  "name": "pickhome",
  "version": "1.3.8",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-data-dirs.mjs",
    "dev": "next dev",
    "build:plz-reference": "node scripts/build-plz-reference.mjs",
    "build:ortsteile-reference": "node scripts/build-ortsteile-reference.mjs",
    "build": "prisma generate && next build",
    "prestart": "node scripts/db-autoupdate.mjs",
    "start": "next start",
    "db:push": "prisma db push",
    "db:push:deploy": "prisma db push --skip-generate --accept-data-loss",
    "db:autoupdate": "node scripts/db-autoupdate.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "data:export": "tsx scripts/backup-export.ts",
    "data:import": "tsx scripts/backup-import.ts",
    "ci": "npm test && npm run build",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.2",
    "leaflet": "^1.9.4",
    "next": "^15.5.18",
    "otpauth": "^9.5.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.15",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
