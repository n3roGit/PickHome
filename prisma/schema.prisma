generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  username      String             @unique
  name          String
  passwordHash  String
  role          String             @default("USER")
  totpSecret    String?
  totpEnabledAt DateTime?
  travelMode     String           @default("driving")
  companyCar     Boolean          @default(false)
  companyCarRate String?
  listPrice      Int?
  marginalTaxRatePercent Int?
  companyCarCommuteMethod String?
  companyCarOfficeTripsPerMonth Int?
  companyCarContributionEur Int?
  companyCarSelfPaidCostsEur Int?
  companyCarEmployerFuelCard Boolean @default(true)
  transitArrivalHour         Int?
  transitArrivalMinute       Int?
  transitArrivalWeekday      Int?
  transitFallbackMaxKm       Int?
  transitFallbackMode        String?
  createdAt      DateTime         @default(now())
  projects      ProjectMember[]
  ratings       Rating[]
  recoveryCodes UserRecoveryCode[]
  addresses     UserAddress[]
}

model UserAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String
  address   String
  latitude  Float?
  longitude Float?
  sortOrder    Int      @default(0)
  isWorkplace  Boolean  @default(false)
  createdAt    DateTime @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  commuteCaches CommuteCache[]

  @@index([userId])
}

model UserRecoveryCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id                String           @id @default(uuid())
  name              String
  budget            Int?
  federalStateCode  String?
  brokerBuyerRate   Float?
  equityAmount      Int?
  loanTermYears     Int?
  interestRate      Float?
  netHouseholdIncome Int?
  dealbreakerThreshold Int           @default(3)
  areaFilterOrtKey  String?
  areaFilterConfig  String?
  icalToken         String?          @unique
  createdAt   DateTime         @default(now())
  archivedAt  DateTime?
  members     ProjectMember[]
  apartments  Apartment[]
  groups      CriterionGroup[]
  areaDistricts ProjectAreaDistrict[]
}

model ProjectAreaDistrict {
  id        String  @id @default(uuid())
  projectId String
  plz       String
  name      String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, plz, name])
  @@index([projectId])
}

model ProjectMember {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  role      String  @default("owner")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model CriterionGroup {
  id        String      @id @default(uuid())
  projectId String
  name      String
  sortOrder Int         @default(0)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criteria  Criterion[]
}

model Criterion {
  id            String         @id @default(uuid())
  groupId       String
  name          String
  weight        Int            @default(3)
  isDealbreaker Boolean        @default(false)
  sortOrder     Int            @default(0)
  group         CriterionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ratings       Rating[]
}

model Apartment {
  id          String               @id @default(uuid())
  projectId   String
  title       String
  address     String?
  latitude    Float?
  longitude   Float?
  price           Int?
  brokerInvolved  Boolean          @default(false)
  sizeSqm         Int?
  floor       Int?
  yearBuilt   Int?
  description String?
  notes       String?
  listingUrl              String?
  listingPriceCheckedAt   DateTime?
  energyClass   String?
  archiveReason String?
  archiveNote   String?
  viewedAt      DateTime?
  archivedAt    DateTime?
  createdAt   DateTime             @default(now())
  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ratings     Rating[]
  photos      ApartmentPhoto[]
  documents   ApartmentDocument[]
  viewings      ViewingAppointment[]
  commuteCaches CommuteCache[]
  priceHistory  ApartmentPriceHistory[]
}

model ApartmentPriceHistory {
  id            String    @id @default(uuid())
  apartmentId   String
  price         Int
  previousPrice Int?
  source        String
  recordedAt    DateTime  @default(now())
  apartment     Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, recordedAt])
}

model CommuteCache {
  apartmentId       String
  userAddressId     String
  travelMode        String
  distanceMeters    Int
  durationSeconds   Int
  routeKind         String?
  connectionSummary String?
  transitDetailJson String?
  effectiveMode     String?
  computedAt        DateTime    @default(now())
  apartment         Apartment   @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  userAddress       UserAddress @relation(fields: [userAddressId], references: [id], onDelete: Cascade)

  @@id([apartmentId, userAddressId, travelMode])
}

model ApartmentDocument {
  id          String    @id @default(uuid())
  apartmentId String
  fileName    String
  url         String
  mimeType    String
  kind        String    @default("expose")
  extractedText String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model ApartmentPhoto {
  id          String    @id @default(uuid())
  apartmentId String
  url         String
  caption     String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model ViewingAppointment {
  id          String    @id @default(uuid())
  apartmentId String
  scheduledAt DateTime
  note        String?
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Rating {
  id          String    @id @default(uuid())
  apartmentId String
  criterionId String
  userId      String
  score       Int?
  note        String?
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  criterion   Criterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, criterionId, userId])
}

model AppSettings {
  id        String   @id @default("default")
  timeZone  String   @default("Europe/Berlin")
  updatedAt DateTime @updatedAt
}

model BackupJobSettings {
  id          String    @id @default("default")
  enabled     Boolean   @default(false)
  hour        Int       @default(4)
  minute      Int       @default(0)
  retainCount Int       @default(7)
  directory   String    @default("")
  lastRunAt   DateTime?
  updatedAt   DateTime  @updatedAt
}

model ListingPriceSyncJobSettings {
  id        String    @id @default("default")
  enabled   Boolean   @default(true)
  hour      Int       @default(6)
  minute    Int       @default(0)
  lastRunAt DateTime?
  updatedAt DateTime  @updatedAt
}

model ProjectReindexJob {
  id           String    @id @default(uuid())
  projectId    String
  kind         String
  status       String
  resultJson   String?
  errorMessage String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?

  @@index([projectId, kind, status])
  @@index([projectId, startedAt])
}
