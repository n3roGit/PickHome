# Local development (npm run dev)
DATABASE_URL="file:../data/pickhome.db"
PICKHOME_DATA_DIR=./data

# Required in production: used to sign session and TOTP login cookies
SESSION_SECRET=change-me-in-production

# Set to false only if you access PickHome over plain HTTP (not recommended)
# COOKIE_SECURE=false

# Docker Compose (set in shell or .env next to docker-compose.yml)
# PICKHOME_PORT=3000

# Optional — public base URL for iCal feed links (use https when behind a reverse proxy)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — LLM (can also be set in Admin → KI)
# PICKHOME_LLM_MODEL=gpt-4o-mini

# Optional — web search for the apartment AI assistant (Admin → KI or env)
# PICKHOME_WEB_SEARCH_API_KEY=tvly-...
# PICKHOME_WEB_SEARCH_PROVIDER=tavily
